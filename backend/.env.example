# Copy to .env.local for local development
# NOTE: Do not commit .env.local

DEBUG=1
SECRET_KEY=dev-secret-key-change-me
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# Django
CSRF_TRUSTED_ORIGINS=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Postgres (docker-compose)
POSTGRES_DB=commonstrange
POSTGRES_USER=commonstrange
POSTGRES_PASSWORD=commonstrange
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0

# Public site base (for preview links etc.)
PUBLIC_SITE_BASE=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ---
# Media storage
# ---
# Set MEDIA_USE_CLOUDINARY=1 + CLOUDINARY_URL for production (free CDN).
# Set MEDIA_USE_S3=1 + AWS_* vars for S3/R2.
# Leave both 0 in local dev to write to MEDIA_ROOT (filesystem fallback).
MEDIA_USE_CLOUDINARY=0
CLOUDINARY_URL=

MEDIA_USE_S3=0
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_REGION_NAME=auto
MEDIA_PUBLIC_BASE_URL=
MEDIA_BUCKET_PREFIX=

# Allow filesystem media fallback in local dev (set to 1 if not using S3/Cloudinary)
ALLOW_FILESYSTEM_MEDIA_FALLBACK=1

# ---
# Email (transactional)
# ---
# In DEBUG=1 mode, emails are printed to the console (no SMTP needed).
# In production (DEBUG=0), set these to a real SMTP provider.
# Recommended: Resend (resend.com) — free tier, 3000 emails/month.
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_PORT=587
#   EMAIL_HOST_USER=resend
#   EMAIL_HOST_PASSWORD=re_your_api_key_here
#   DEFAULT_FROM_EMAIL=Common Strange <noreply@yourdomain.com>
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=Common Strange <noreply@commonstrange.com>

# ---
# Optional integrations
# ---
SENTRY_DSN=
