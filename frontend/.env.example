# Copy to .env.local for local development
# NOTE: Do not commit .env.local

# ---
# Public site URL
# Used for canonical links, OpenGraph URLs, sitemap, robots.txt, metadataBase.
# In production: set to your live domain (e.g. https://commonstrange.onrender.com)
# ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---
# Backend API URLs
# ---
# NEXT_PUBLIC_BACKEND_BASE — used by the frontend proxy route (/v1/[[...path]])
# to forward browser requests to the Django backend. In Docker this is the
# internal Docker DNS name; in production it is the deployed backend URL.
NEXT_PUBLIC_BACKEND_BASE=http://backend:8000

# BACKEND_INTERNAL_URL — optional runtime override for server-side fetches
# (Next.js server components / route handlers). Set this on Render/PaaS to the
# internal service URL so server-side requests bypass the public internet.
# Leave empty in local dev; Next.js will fall back to NEXT_PUBLIC_API_BASE.
BACKEND_INTERNAL_URL=

# NEXT_PUBLIC_API_BASE — public-facing backend base for client-side use.
# Leave empty in local dev to use the same-origin /v1/* proxy (avoids CORS).
# In production: set to the deployed backend URL if not using the proxy.
NEXT_PUBLIC_API_BASE=

# ---
# Feature flags
# ---
# Set to 1 to enable Google Analytics / Search Console pageview tracking.
NEXT_PUBLIC_ENABLE_ANALYTICS=0
